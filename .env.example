# Banco de dados (asyncpg para produção; aiosqlite para testes)
DATABASE_URL=postgresql+asyncpg://obra:obra@localhost:5432/orcamento_obra

# Segurança — API REST e MCP (gere com: openssl rand -hex 32)
API_KEY=change-me-random-string-here

# Autenticação da UI web (Basic Auth)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-me

# Anthropic (para integração MCP com Claude.ai)
ANTHROPIC_API_KEY=sk-ant-...

# App
APP_ENV=development
LOG_LEVEL=INFO

# Deploy — variáveis adicionais usadas no docker-compose.yml de produção
# GHCR_OWNER=fredricci
# DOMAIN=obraapp.duckdns.org
# POSTGRES_DB=orcamento_obra
# POSTGRES_USER=obra
# POSTGRES_PASSWORD=change-me-random-string-here
# BUCKET_NAME=orcamento-obra-backup-123456789012
# DB_CONTAINER=deploy-db-1
# DB_NAME=orcamento_obra
